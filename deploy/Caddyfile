# Single-origin front door for the self-host bundle.
# Everything is served from one origin (:3000) so the Clerk __session httpOnly cookie
# set by the backend reaches the SPA and the API alike.
:3000 {
	encode zstd gzip

	# API → backend (the NestJS global prefix is /api/v1, so /api/* covers it).
	handle /api/* {
		reverse_proxy server:4000
	}

	# SPA static assets + client-side routing fallback.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
