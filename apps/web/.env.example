# Leave empty → API goes relative (/api), Vite proxy forwards to backend (:4000).
# Same-origin flow is required for Clerk httpOnly cookie to reach the backend.
VITE_API_URL=

# Clerk publishable key — get from your Clerk app at https://clerk.com (Organizations must be enabled).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# Billing: Polar (Merchant of Record) uses hosted-redirect checkout — the backend
# creates the checkout session and returns a URL, so no client-side billing keys are needed.

# PostHog analytics — project token from posthog.com project settings.
# Empty = analytics fully disabled (dev default). Host: us.i or eu.i by region.
# Privacy-restricted mode is hardcoded in src/lib/analytics.tsx (memory persistence,
# no autocapture, no session recording, respect DNT).
VITE_POSTHOG_PROJECT_TOKEN=
VITE_POSTHOG_HOST=https://us.i.posthog.com
