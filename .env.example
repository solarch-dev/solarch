# ─────────────────────────────────────────────────────────────────────────────
# Solarch self-host configuration. Copy to `.env`, fill the values, then run:
#   docker compose up --build   →   http://localhost:3000
#
# Only Neo4j + Clerk + one AI provider key are needed for a working instance.
# Everything else is optional and degrades gracefully when left blank.
# ─────────────────────────────────────────────────────────────────────────────

# Public URL the app is served on (used for CORS). Default is fine for local self-host.
PUBLIC_URL=http://localhost:3000
# Host port to publish (the container always listens on 3000 internally).
PORT_PUBLIC=3000

# ── Database (Neo4j) ─────────────────────────────────────────────────────────
# Use a strong password for anything beyond local testing. NOTE: the password is
# only written on the FIRST run (initial volume); to change it later, reset the volume.
NEO4J_PASSWORD=change_me_please
# Memory tuning for a single box (Neo4j + server + proxy share the host).
# NEO4J_HEAP=512m
# NEO4J_PAGECACHE=512m

# ── Auth (Clerk) — required for sign-in ──────────────────────────────────────
# Create an app at https://clerk.com (enable Organizations), then copy the keys.
# The publishable key must be set in BOTH places (server runtime + web build).
CLERK_SECRET_KEY=sk_test_xxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
# Optional CSRF hardening — comma-separated allowed origins.
# CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Guest mode (try one project without signing in). Sign the tickets with a random
# secret: `openssl rand -hex 32`. Leave blank to disable guest mode.
GUEST_TOKEN_SECRET=

# ── AI provider — required for the AI Architect / chat ───────────────────────
# Any OpenAI-compatible chat provider works. The default is DeepSeek (proven tool
# calling). To use an AWS Bedrock OpenAI-compatible endpoint instead, set the
# providers to `bedrock` and fill the BEDROCK_* block.
LLM_GENERATION_PROVIDER=deepseek
LLM_CHAT_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL_AGENT=deepseek-v4-pro
# DEEPSEEK_MODEL_INSTRUCT=deepseek-v4-flash
#
# Bedrock (OpenAI-compatible) — only if LLM_*_PROVIDER=bedrock
# BEDROCK_API_KEY=
# BEDROCK_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/v1
# AWS_REGION=us-east-1
# BEDROCK_MODEL=moonshotai.kimi-k2.5

# ── Embeddings (GraphRAG) — local by default, no key needed ──────────────────
# Runs on-box via ONNX (multilingual, 384-d). The Docker image pre-fetches the model.
# EMBED_PROVIDER=local
# EMBED_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2

# ── Billing (Polar — optional) ───────────────────────────────────────────────
# Leave blank to run without billing/entitlement gating.
# POLAR_SERVER=sandbox
# POLAR_ACCESS_TOKEN=
# POLAR_WEBHOOK_SECRET=
# POLAR_PRODUCT_DRAW=
# POLAR_PRODUCT_BUILD=
# POLAR_PRODUCT_CODE=

# ── Analytics (PostHog — optional, web) ──────────────────────────────────────
# VITE_POSTHOG_PROJECT_TOKEN=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
